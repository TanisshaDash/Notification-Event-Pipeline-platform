{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "jsx": "react-jsx",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src"]
}
